{
  "gameIdentity": {
    "name": "Neon Swarm Runner",
    "genre": "two-lane survival shooter",
    "visualTarget": "Neon geometry with motion-graphics polish, procedural trails, glow, beams, slashes, and readable silhouettes",
    "coreConstraint": "Everything should be achievable with procedural shapes, gradients, trails, particles, simple shaders, and instanced geometry. Avoid hand-authored art pipelines."
  },
  "layout": {
    "laneCount": 2,
    "laneWidth": 88,
    "playerRadius": 10,
    "defaultEnemyRadius": 9,
    "largeEnemyRadius": 14,
    "pickupRadius": 8,
    "projectileRadius": 3,
    "rowSpacing": 32,
    "maxEnemiesVisible": 28,
    "maxEnemiesPerLaneVisible": 14,
    "agentNotes": {
      "intent": "Shrink the player and enemies so the screen can support more simultaneous action without requiring more lanes.",
      "must": [
        "Keep enemies readable at small sizes.",
        "Use silhouette and motion to distinguish enemies, not size alone.",
        "Avoid making bosses gigantic; make them denser, layered, faster, shielded, or more mechanically interesting instead."
      ],
      "avoid": [
        "Huge enemies that reduce screen density.",
        "Large player sprite that blocks action.",
        "Empty lanes with one enemy at a time."
      ],
      "expectation": "The screen should feel busier, sharper, and more tactical after scaling down. The player should be able to see several threats and pickups at once."
    }
  },
  "visualSystem": {
    "style": {
      "base": "neonGeometry",
      "background": "darkGrid",
      "camera": "slightlyZoomedOutForwardRunner",
      "primaryEffects": [
        "glow",
        "trails",
        "screenSpaceParticles",
        "proceduralPolylines",
        "gradientFills",
        "simpleBloom"
      ]
    },
    "visualBudget": {
      "maxTotalVisualCost": 18,
      "maxOrbitingElements": 8,
      "maxPersistentParticles": 90,
      "maxTemporaryParticles": 160,
      "maxActiveBeams": 4,
      "maxActiveSlashEffects": 3,
      "maxActiveLightningChains": 3,
      "maxMissileTrails": 8,
      "maxPickupGlowRings": 10
    },
    "shapeRules": {
      "enemyCirclesAllowed": false,
      "pickupCirclesAllowed": true,
      "shieldCirclesAllowed": true,
      "projectileCirclesAllowed": true,
      "allWeaponsCanBeOrbs": false,
      "preferredEnemySilhouettes": [
        "triangle",
        "diamond",
        "square",
        "hexagon",
        "wideHexagon",
        "nestedPolygon",
        "crackedDiamond",
        "chevron"
      ],
      "preferredWeaponSilhouettes": [
        "tinyBullet",
        "bulletStream",
        "beamLine",
        "curvedSlash",
        "jaggedLightning",
        "missileTriangle",
        "droneTriangle",
        "pulseRing"
      ],
      "preferredShieldSilhouettes": [
        "hexSegments",
        "frontBarrier",
        "orbiters",
        "softAura",
        "expandingPulse",
        "reactiveShards"
      ]
    },
    "agentNotes": {
      "intent": "Use a small number of reusable procedural rendering techniques to create many distinct effects.",
      "must": [
        "Every major weapon family needs a different motion language.",
        "Every enemy family needs a different silhouette.",
        "Every shield family needs a different defensive personality.",
        "Prefer effects that look expensive but are cheap: trails, polylines, rings, arcs, beams, and simple particles."
      ],
      "avoid": [
        "Everything becoming glowing orbs.",
        "Sprite-sheet dependencies.",
        "Character animation complexity.",
        "Unclear hit areas.",
        "Particle spam that hides lanes."
      ],
      "expectation": "The game should look like a high-energy neon motion-graphics shooter, not a placeholder shape demo. It should still be practical for browser rendering and agentic coding."
    }
  },
  "player": {
    "base": {
      "hp": 3,
      "radius": 10,
      "lane": 0,
      "moveDurationMs": 95,
      "weaponSlots": 3,
      "shieldSlots": 1,
